# ── Database ─────────────────────────────────────────
# PostgreSQL connection string
# Local:      postgres://user:password@localhost:5432/portfolio
# Supabase:   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgres://user:password@localhost:5432/portfolio

# ── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────
# URL of your frontend (used in production)
FRONTEND_URL=https://your-portfolio.vercel.app

# ── Email (optional) ─────────────────────────────────
# Fill these to get email notifications on contact form submissions
SMTP_HOST=smtp.gmail.com
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=you@gmail.com
